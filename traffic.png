endedAuthorOrArticleInformation":"\u003Cp\u003ESmarter Than You Think: Articles in\nthis series are\nexamining the\nrecent advances\nin artificial\nintelligence\nand robotics\nand\ntheir potential impact on society.\u003C\u002Fp\u003E","htmlInfoBox":"","reviewInformation":""},"newsStatus":"DEFAULT","originalDesk":"","printInformation":{"__typename":"PrintInformation","edition":"NewYork","headline":"Look Officer, No Hands: Google Car Drives Itself","page":"1","publicationDate":"2010-10-10T04:00:00.000Z","section":"A"},"promotionalImage":{"__typename":"PromotionalImage","image":{"__typename":"Image","caption":{"__typename":"TextOnlyDocumentBlock","text":"Computer hardware in the trunk of one of the seven self-driving test vehicles."},"credit":"Ramin Rahimian for The New York Times","crops":[],"id":"SW1hZ2U6bnl0Oi8vaW1hZ2UvYTgwM2ViNWUtMmE3MC01ZmViLTgxNGQtOTE5M2FmYjkzOWQ4"},"socialMediaRendition":null,"twitterRendition":null},"promotionalMedia":{"__typename":"Image","assetCrops":[{"__typename":"ImageCrop","name":"SMALL_SQUARE","renditions":[{"__typename":"ImageRendition","height":75,"name":"thumbStandard","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google3\u002F10google3-thumbStandard.jpg","width":75}]}],"caption":{"__typename":"TextOnlyDocumentBlock","text":"Computer hardware in the trunk of one of the seven self-driving test vehicles."},"credit":"Ramin Rahimian for The New York Times","id":"SW1hZ2U6bnl0Oi8vaW1hZ2UvYTgwM2ViNWUtMmE3MC01ZmViLTgxNGQtOTE5M2FmYjkzOWQ4"},"requestToCommentEnabled":false,"reviewItems":[],"reviewSummary":"","rights":{"__typename":"Rights","category":"NCE"},"section":{"__typename":"Section","displayName":"Science","id":"U2VjdGlvbjpueXQ6Ly9zZWN0aW9uL2ZiMjQxZTE2LWNiZGUtNWQ2MC1iZTZlLTZiY2E5ZTg2YzY5Nw==","name":"science","uri":"nyt:\u002F\u002Fsection\u002Ffb241e16-cbde-5d60-be6e-6bca9e86c697","url":"https:\u002F\u002Fwww.nytimes.com\u002Fsection\u002Fscience"},"shareCardExperience":false,"slug":"10google","source":{"__typename":"Organization","displayName":"New York Times","id":"T3JnYW5pemF0aW9uOm55dDovL29yZ2FuaXphdGlvbi9jMjc5MTM4OC02YjE2LTVmZmQtYTExOS05NmVhY2IxOTg5YzE="},"sourceId":"1248069157627","sourcePublisher":"scoop","sprinkled":{"__typename":"SprinkledContent","configs":[{"__typename":"SprinkledConfig","name":"mobile","stride":4,"threshold":3},{"__typename":"SprinkledConfig","name":"desktop","stride":5,"threshold":3},{"__typename":"SprinkledConfig","name":"mobileHoldout","stride":4,"threshold":3},{"__typename":"SprinkledConfig","name":"desktopHoldout","stride":5,"threshold":3},{"__typename":"SprinkledConfig","name":"hybrid","stride":4,"threshold":3},{"__typename":"SprinkledConfig","name":"hybridHoldout","stride":4,"threshold":3}]},"sprinkledBody":{"__typename":"DocumentBlock","content":[{"__typename":"HeaderLegacyBlock","byline":{"__typename":"BylineBlock","bylines":[{"__typename":"Byline","creators":[{"__typename":"Person","bioUrl":"https:\u002F\u002Fwww.nytimes.com\u002Fby\u002Fjohn-markoff","displayName":"John Markoff","id":"UGVyc29uOm55dDovL3BlcnNvbi8xMWZlNzkwMC1lYTgwLTUxN2EtOTYzMy0zODYwYjNiMTFmNWM=","promotionalMedia":{"__typename":"Image","crops":[{"__typename":"ImageCrop","renditions":[{"__typename":"ImageRendition","name":"thumbLarge","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2007\u002F06\u002F25\u002Ftechnology\u002F25markoff.ready\u002F25markoff.ready-thumbLarge-v3.jpg"}]}],"id":"SW1hZ2U6bnl0Oi8vaW1hZ2UvNmFjYTcwZDQtOTEzZS01MGFlLWJhMWItM2M0NDk1MjkzYWZl"}}],"prefix":"By","renderedRepresentation":"By John Markoff"}],"hideHeadshots":false,"role":[],"textAlign":"DEFAULT"},"headline":{"__typename":"Heading1Block","content":[{"__typename":"TextInline","formats":[],"text":"Google Cars Drive Themselves, in Traffic"}],"textAlign":"DEFAULT"},"label":{"__typename":"LabelBlock","content":[{"__typename":"TextInline","formats":[],"text":"Smarter Than You Think"}],"textAlign":"DEFAULT"},"ledeMedia":{"__typename":"ImageBlock","desktopCrop":null,"hasMobileSize":false,"media":{"__typename":"Image","altText":"","caption":{"__typename":"TextOnlyDocumentBlock","content":[{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"Dmitri Dolgov, a Google engineer, in a self-driving car parked in Silicon Valley after a road test."}]}],"text":"Dmitri Dolgov, a Google engineer, in a self-driving car parked in Silicon Valley after a road test."},"credit":"Ramin Rahimian for The New York Times","crops":[{"__typename":"ImageCrop","renditions":[{"__typename":"ImageRendition","height":358,"name":"articleLarge","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google-span\u002F10google-span-articleLarge.jpg","width":600},{"__typename":"ImageRendition","height":676,"name":"jumbo","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google-span\u002F10google-span-jumbo.jpg","width":1024},{"__typename":"ImageRendition","height":429,"name":"popup","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google-span\u002F10google-span-popup.jpg","width":650}]}],"id":"SW1hZ2U6bnl0Oi8vaW1hZ2UvNDZkMmQ2MDUtMTYxZi01YzlhLTg5MWYtZTMxZTM3MDQ1Y2Uy","imageType":"photo","legacyHtmlCaption":"Dmitri Dolgov, a Google engineer, in a self-driving car parked in Silicon Valley after a road test.","timesTags":[],"uri":"nyt:\u002F\u002Fimage\u002F46d2d605-161f-5c9a-891f-e31e37045ce2","url":"https:\u002F\u002Fwww.nytimes.com\u002Fimagepages\u002F2010\u002F10\u002F10\u002Fus\u002F10google-span.html"},"mobileAltText":null,"mobileCaption":null,"mobileCredit":null,"mobileCrop":null,"mobileMedia":null,"mobileSize":null,"size":"MEDIUM"},"subhead":null,"timestampBlock":{"__typename":"TimestampBlock","align":"DEFAULT","showUpdatedTimestamp":null,"timestamp":"2010-10-09T18:33:45.000Z"}},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"MOUNTAIN VIEW, Calif.  Anyone driving the twists of Highway 1 between San Francisco and Los Angeles recently may have glimpsed a Toyota Prius with a curious funnel-like cylinder on the roof. Harder to notice was that the person at the wheel was not actually driving. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":0},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The car is a project of Google, which has been working in secret but in plain view on vehicles that can drive themselves, using artificial-intelligence software that can sense anything near the car and mimic the decisions made by a human driver. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":1},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"With someone behind the wheel to take control if something goes awry and a technician in the passenger seat to monitor the navigation system, seven test cars have driven 1,000 miles without human intervention and more than 140,000 miles with only occasional human control. One even drove itself down Lombard Street in San Francisco, one of the steepest and curviest streets in the nation."},{"__typename":"TextInline","formats":[{"__typename":"BoldFormat","type":null}],"text":" "},{"__typename":"TextInline","formats":[],"text":"The only accident, engineers said, was when one Google car was rear-ended while stopped at a traffic light."}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":2},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"Autonomous cars are years from mass production, but technologists who have long dreamed of them believe that they can transform society as profoundly as the Internet has. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":true,"adsDesktopHoldout":true,"adsHybrid":true,"adsHybridHoldout":true,"adsMobile":true,"adsMobileHoldout":true,"bad":false,"index":3},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"Robot drivers react faster than humans, have 360-degree perception and do not get distracted, sleepy or intoxicated, the engineers argue. They speak in terms of lives saved and injuries avoided  more than 37,000 people died in car accidents in the United States in 2008. The engineers say the technology could double the capacity of roads by allowing cars to drive more safely while closer together. Because the robot cars would eventually be less likely to crash, they could be built lighter, reducing fuel consumption. But of course, to be truly safer, the cars must be far more reliable than, say, today’s personal computers, which crash on occasion and are frequently infected."}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":4},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The Google research program using artificial intelligence to revolutionize the automobile is proof that the company’s ambitions reach beyond the search engine business. The program is also a departure from the mainstream of innovation in Silicon Valley, which has veered toward social networks and Hollywood-style digital media."}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":5},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"During a half-hour drive beginning on Google’s campus 35 miles south of San Francisco last Wednesday, a Prius equipped with a variety of sensors and following a route programmed into the GPS navigation system nimbly accelerated in the entrance lane and merged into fast-moving traffic on Highway 101, the freeway through Silicon Valley. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":true,"adsHybridHoldout":true,"adsMobile":true,"adsMobileHoldout":true,"bad":false,"index":6},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"It drove at the speed limit, which it knew because the limit for every road is included in its database, and left the freeway several exits later. The device atop the car produced a detailed map of the environment. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":true,"index":7},{"__typename":"ImageBlock","desktopCrop":null,"hasMobileSize":false,"media":{"__typename":"Image","altText":"","caption":{"__typename":"TextOnlyDocumentBlock","content":[{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"A self-driving car developed and outfitted by Google, with device on roof, cruising along recently on Highway 101 in Mountain View, Calif."}]}],"text":"A self-driving car developed and outfitted by Google, with device on roof, cruising along recently on Highway 101 in Mountain View, Calif."},"credit":"Ramin Rahimian for The New York Times","crops":[{"__typename":"ImageCrop","renditions":[{"__typename":"ImageRendition","height":681,"name":"jumbo","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google2\u002F10google2-jumbo.jpg","width":1024},{"__typename":"ImageRendition","height":432,"name":"popup","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google2\u002F10google2-popup.jpg","width":650}]},{"__typename":"ImageCrop","renditions":[{"__typename":"ImageRendition","height":140,"name":"articleInline","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google2\u002F10google2-articleInline.jpg","width":190}]}],"id":"SW1hZ2U6bnl0Oi8vaW1hZ2UvMzNkODBjYTctYmEyMS01MzkzLThjZDItZjE3ZGJhMTAwYWQ1","imageType":"photo","legacyHtmlCaption":"A self-driving car developed and outfitted by Google, with device on roof, cruising along recently on Highway 101 in Mountain View, Calif.","timesTags":[],"uri":"nyt:\u002F\u002Fimage\u002F33d80ca7-ba21-5393-8cd2-f17dba100ad5","url":"https:\u002F\u002Fwww.nytimes.com\u002Fimagepages\u002F2010\u002F10\u002F10\u002Fus\u002F10google2.html"},"mobileAltText":null,"mobileCaption":null,"mobileCredit":null,"mobileCrop":null,"mobileMedia":null,"mobileSize":null,"size":"MEDIUM"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":true,"index":8},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The car then drove in city traffic through Mountain View, stopping for lights and stop signs, as well as making announcements like “approaching a crosswalk” (to warn the human at the wheel) or “turn ahead” in a pleasant female voice. This same pleasant voice would, engineers said, alert the driver if a master control system detected anything amiss with the various sensors. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":true,"adsDesktopHoldout":true,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":9},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The car can be programmed for different driving personalities  from cautious, in which it is more likely to yield to another car, to aggressive, where it is more likely to go first. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":10},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"Christopher Urmson, a Carnegie Mellon University robotics scientist, was behind the wheel but not using it. To gain control of the car he has to do one of three things: hit a red button near his right hand, touch the brake or turn the steering wheel. He did so twice, once when a bicyclist ran a red light and again when a car in front stopped and began to back into a parking space. But the car seemed likely to have prevented an accident itself. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":true,"adsHybridHoldout":true,"adsMobile":true,"adsMobileHoldout":true,"bad":false,"index":11},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"When he returned to automated “cruise” mode, the car gave a little “whir” meant to evoke going into warp drive on “Star Trek,” and Dr. Urmson was able to rest his hands by his sides or gesticulate when talking to a passenger in the back seat. He said the cars did attract attention, but people seem to think they are just the next generation of the Street View cars that Google uses to take photographs and collect data for its maps. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":12},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The project is the brainchild of Sebastian Thrun, the 43-year-old director of the Stanford Artificial Intelligence Laboratory, a Google engineer and the co-inventor of the Street View mapping service. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":true,"adsDesktopHoldout":true,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":13},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"In 2005, he led a team of Stanford students and faculty members in designing the Stanley robot car, winning the second Grand Challenge of the Defense Advanced Research Projects Agency, a $2 million Pentagon prize for driving autonomously over 132 miles in the desert. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":14},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":" Besides the team of 15 engineers working on the current project, Google hired more than a dozen people, each with a spotless driving record, to sit in the driver’s seat, paying $15 an hour or more. Google is using six Priuses and an Audi TT in the project. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":true,"adsHybridHoldout":true,"adsMobile":true,"adsMobileHoldout":true,"bad":false,"index":15},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The Google researchers said the company did not yet have a clear plan to create a business from the experiments. Dr. Thrun is known as a passionate promoter of the potential to use robotic vehicles to make highways safer and lower the nation’s energy costs. It is a commitment shared by Larry Page, Google’s co-founder, according to several people familiar with the project."}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":16},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The self-driving car initiative is an example of Google’s willingness to gamble on technology that may not pay off for years, Dr. Thrun said. Even the most optimistic predictions put the deployment of the technology more than eight years away. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":true,"index":17},{"__typename":"ImageBlock","desktopCrop":null,"hasMobileSize":false,"media":{"__typename":"Image","altText":"","caption":{"__typename":"TextOnlyDocumentBlock","content":[{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"Computer hardware in the trunk of one of the seven self-driving test vehicles."}]}],"text":"Computer hardware in the trunk of one of the seven self-driving test vehicles."},"credit":"Ramin Rahimian for The New York Times","crops":[{"__typename":"ImageCrop","renditions":[{"__typename":"ImageRendition","height":683,"name":"jumbo","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google3\u002F10google3-jumbo.jpg","width":1024},{"__typename":"ImageRendition","height":433,"name":"popup","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google3\u002F10google3-popup.jpg","width":650}]},{"__typename":"ImageCrop","renditions":[{"__typename":"ImageRendition","height":121,"name":"articleInline","url":"https:\u002F\u002Fstatic01.nyt.com\u002Fimages\u002F2010\u002F10\u002F10\u002Fus\u002F10google3\u002F10google3-articleInline.jpg","width":190}]}],"id":"SW1hZ2U6bnl0Oi8vaW1hZ2UvYTgwM2ViNWUtMmE3MC01ZmViLTgxNGQtOTE5M2FmYjkzOWQ4","imageType":"photo","legacyHtmlCaption":"Computer hardware in the trunk of one of the seven self-driving test vehicles.","timesTags":[],"uri":"nyt:\u002F\u002Fimage\u002Fa803eb5e-2a70-5feb-814d-9193afb939d8","url":"https:\u002F\u002Fwww.nytimes.com\u002Fimagepages\u002F2010\u002F10\u002F10\u002Fus\u002F10google3.html"},"mobileAltText":null,"mobileCaption":null,"mobileCredit":null,"mobileCrop":null,"mobileMedia":null,"mobileSize":null,"size":"MEDIUM"},{"__typename":"Dropzone","adsDesktop":true,"adsDesktopHoldout":true,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":true,"index":18},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"One way Google might be able to profit is to provide information and navigation services for makers of autonomous vehicles. Or, it might sell or give away the navigation technology itself, much as it offers its Android smart phone system to cellphone companies."}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":true,"adsHybridHoldout":true,"adsMobile":true,"adsMobileHoldout":true,"bad":false,"index":19},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":" But the advent of autonomous vehicles poses thorny legal issues, the Google researchers acknowledged. Under current law, a human must be in control of a car at all times, but what does that mean if the human is not really paying attention as the car crosses through, say, a school zone, figuring that the robot is driving more safely than he would?"}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":20},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"And in the event of an accident, who would be liable  the person behind the wheel or the maker of the software? "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":21},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"“The technology is ahead of the law in many areas,” said Bernard Lu, senior staff counsel for the California Department of Motor Vehicles. “If you look at the vehicle code, there are dozens of laws pertaining to the driver of a vehicle, and they all presume to have a human being operating the vehicle.”"}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":22},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The Google researchers said they had carefully examined California’s motor vehicle regulations and determined that because a human driver can override any error, the experimental cars are legal. Mr. Lu agreed."}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":true,"adsDesktopHoldout":true,"adsHybrid":true,"adsHybridHoldout":true,"adsMobile":true,"adsMobileHoldout":true,"bad":false,"index":23},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":" Scientists and engineers have been designing autonomous vehicles since the mid-1960s, but crucial innovation happened in 2004 when the Pentagon’s research arm began its Grand Challenge. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":24},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"The first contest ended in failure, but in 2005, Dr. Thrun’s Stanford team built the car that won a race with a rival vehicle built by a team from Carnegie Mellon University. Less than two years later, another event proved that autonomous vehicles could drive safely in urban settings."}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":25},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"Advances have been so encouraging that Dr. Thrun sounds like an evangelist when he speaks of robot cars. There is their potential to reduce fuel consumption by eliminating heavy-footed stop-and-go drivers and, given the reduced possibility of accidents, to ultimately build more lightweight vehicles. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":26},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":"There is even the farther-off prospect of cars that do not need anyone behind the wheel. That would allow the cars to be summoned electronically, so that people could share them. Fewer cars would then be needed, reducing the need for parking spaces, which consume valuable land. "}],"textAlign":"DEFAULT"},{"__typename":"Dropzone","adsDesktop":false,"adsDesktopHoldout":false,"adsHybrid":false,"adsHybridHoldout":false,"adsMobile":false,"adsMobileHoldout":false,"bad":false,"index":27},{"__typename":"ParagraphBlock","content":[{"__typename":"TextInline","formats":[],"text":" And, of course, the cars could save humans from themselves. “Can we text twice as much while driving, without the guilt?” Dr. Thrun said in a recent talk. “Yes, we can, if only cars will drive themselves.”"}],"textAlign":"DEFAULT"}]},"storyFormat":null,"storylines":[{"__typename":"AssociatedStoryline","ruleName":"styln-artificial-intelligence","storyline":{"__typename":"Storyline","context":null,"displayName":"Artificial Intelligence","experimentalJsonBlob":"{\"data\":[{\"version\":1,\"type\":\"experimentalJsonBlob\",\"data\":[]}]}","hubAssets":[{"__typename":"StorylineHubAsset","asset":{"__typename":"LegacyCollection","id":"TGVnYWN5Q29sbGVjdGlvbjpueXQ6Ly9sZWdhY3ljb2xsZWN0aW9uLzJhNGZhOTU3LTQ0YzktNWVmOC1iMDUwLTMyNDk5NzE1OTY2OA==","uri":"nyt:\u002F\u002Flegacycollection\u002F2a4fa957-44c9-5ef8-b050-324997159668","url":"https:\u002F\u002Fwww.nytimes.com\u002Fspotlight\u002Fartificial-intelligence"}}],"primaryAssets":[{"__typename":"StorylinePrimaryAsset","asset":{"__typename":"Article","uri":"nyt:\u002F\u002Farticle\u002Fd6152562-b087-5506-a491-0935d4fe4770","url":"https:\u002F\u002Fwww.nytimes.com\u002F2026\u002F05\u002F19\u002Fbusiness\u002Fgoogle-seach-bar-ai-gemini.html"},"displayName":"Google’s Search Box","status":null},{"__typename":"StorylinePrimaryAsset","asset":{"__typename":"Article","uri":"nyt:\u002F\u002Farticle\u002F863ff2cc-44fa-512b-ab05-e215d823e506","url":"https:\u002F\u002Fwww.nytimes.com\u002F2026\u002F05\u002F14\u002Ftechnology\u002Fartificial-intelligence-safety-controls.html"},"displayName":"The Poetry Loophole","status":null},{"__typename":"StorylinePrimaryAsset","asset":{"__typename":"Article","uri":"nyt:\u002F\u002Farticle\u002Fcf084306-5de8-5b03-855e-97154e563215","url":"https:\u002F\u002Fwww.nytimes.com\u002F2026\u002F05\u002F12\u002Ftechnology\u002Fai-cybersecurity-competition.html"},"displayName":"Cybersecurity Showdown","status":null},{"__typename":"StorylinePrimaryAsset","asset":{"__typename":"Article","uri":"nyt:\u002F\u002Farticle\u002F5588c4ec-dc3f-5e10-85a8-c139689b1625","url":"https:\u002F\u002Fwww.nytimes.com\u002F2026\u002F05\u002F12\u002Ftechnology\u002Fchatgpt-lawsuit-wrongful-death.html"},"displayName":"Wrongful Death Lawsuits","status":null},{"__typename":"StorylinePrimaryAsset","asset":{"__typename":"Article","uri":"nyt:\u002F\u002Farticle\u002Ff967f9e5-6931-5b7f-9ac2-fb58d1f1508c","url":"https:\u002F\u002Fwww.nytimes.com\u002F2026\u002F05\u002F08\u002Fmagazine\u002Fai-populism-backlash-altman.html"},"displayName":"A.I. Populism","status":null},{"__typename":"StorylinePrimaryAsset","asset":{"__typename":"Article","uri":"nyt:\u002F\u002Farticle\u002F1658a202-f4e4-5d77-a5d0-9acc9cb8379a","url":"https:\u002F\u002Fwww.nytimes.com\u002F2026\u002F05\u002F05\u002Ftechnology\u002Fapple-intelligence-lawsuit-settlement.html"},"displayName":"Apple Settlement","status":null}],"promotedLiveAssets":[],"tone":"NO_TONE_SET","topLinks":null,"uri":"nyt:\u002F\u002Fstoryline\u002Fc3f19d9c-d2cb-4619-8aea-ec3afa27be39","url":"https:\u002F\u002Fwww.nytimes.com\u002Fstoryline\u002Fc3f19d9c-d2cb-4619-8aea-ec3afa27be39"},"testName":""},{"__typename":"AssociatedStoryline","ruleName":"styln-health-science-general","storyline":{"__typename":"Storyline","context":null,"displayName":"Health and Science","experimentalJsonBlob":"{\"data\":[{\"version\":1,\"type\":\"experimentalJsonBlob\",\"data\":[]}]}","hubAssets":[],"primaryAssets":[],"promotedLiveAssets":[],"tone":"NEWS","topLinks":null,"uri":"nyt:\u002F\u002Fstoryline\u002F9343ef2d-5c74-4232-a8cb-ef3c9ad013ae","url":"https:\u002F\u002Fwww.nytimes.com\u002Fstoryline\u002F9343ef2d-5c74-4232-a8cb-ef3c9ad013ae"},"testName":""},{"__typename":"AssociatedStoryline","ruleName":"styln-national-general","storyline":{"__typename":"Storyline","context":null,"displayName":"Best of National","experimentalJsonBlob":"{\"data\":[{\"version\":1,\"type\":\"experimentalJsonBlob\",\"data\":[]}]}","hubAssets":[],"primaryAssets":[],"promotedLiveAssets":[],"tone":"NEWS","topLinks":null,"uri":"nyt:\u002F\u002Fstoryline\u002F05a4fa2d-a5a9-4322-9f9f-1154a38a0ed3","url":"https:\u002F\u002Fwww.nytimes.com\u002Fstoryline\u002F05a4fa2d-a5a9-4322-9f9f-1154a38a0ed3"},"testName":""}],"subsection":null,"summary":"Google has been working on vehicles that can drive themselves using software.","timesTags":[{"__typename":"Subject","associatedLegacyCollections":[],"displayName":"Robots